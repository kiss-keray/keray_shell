{
  "name": "keray_shell_rust",
  "version": "0.1.4",
  "private": false,
  "description": "A Tauri SSH and SFTP desktop client.",
  "author": "Keray",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "dev": "pnpm --dir web-next dev",
    "react:devtools": "pnpm --dir web-next devtools",
    "build": "pnpm --dir web-next build",
    "preview": "pnpm --dir web-next start",
    "type-check": "pnpm --dir web-next type-check",
    "lint": "pnpm --dir web-next lint",
    "test": "pnpm --dir web-next test",
    "vue:dev": "vite",
    "vue:build": "run-p vue:type-check \"vue:build-only {@}\" --",
    "vue:preview": "vite preview",
    "vue:build-only": "vite build",
    "vue:type-check": "vue-tsc --noEmit -p tsconfig.app.json",
    "vue:lint": "eslint . --fix",
    "format": "prettier --write src/",
    "tauri": "tauri",
    "set-version": "node scripts/set-version.mjs"
  },
  "dependencies": {
    "@iconify/vue": "^5.0.0",
    "@tailwindcss/vite": "^4.2.4",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-dialog": "^2",
    "@tauri-apps/plugin-fs": "^2",
    "@tauri-apps/plugin-log": "~2.8.0",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-os": "^2.3.2",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-image": "^0.9.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-serialize": "^0.14.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "crypto-es": "^3.1.3",
    "dayjs": "^1.11.20",
    "md5": "^2.3.0",
    "mitt": "^3.0.1",
    "monaco-editor": "^0.55.1",
    "pinia": "^3.0.4",
    "tailwindcss": "^4.2.4",
    "vue": "^3.5.33",
    "vuedraggable": "^4.1.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@tsconfig/node24": "latest",
    "@types/md5": "^2.3.6",
    "@types/node": "^25.6.0",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vitejs/plugin-vue-jsx": "^5.1.5",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^10.2.1",
    "eslint-plugin-vue": "~10.9.0",
    "jiti": "^2.6.1",
    "npm-run-all2": "^8.0.4",
    "prettier": "3.8.3",
    "sass": "1.99.0",
    "typescript": "~6.0.3",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-icons": "^23.0.1",
    "unplugin-vue-components": "^32.0.0",
    "vite": "^8.0.9",
    "vite-plugin-vue-devtools": "^8.1.1",
    "vue-tsc": "^3.2.7"
  }
}
